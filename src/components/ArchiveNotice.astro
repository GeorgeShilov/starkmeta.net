---
import { site } from "@/config/site";
---

<section class="archive-notice">
  <div>
    <strong>Now building</strong>
    <p>
      StarkMeta is building Unreal Engine-based metaverse worlds and P2E NFT games: immersive cities,
      racing arenas, and digital collectibles with true ownership.
    </p>
  </div>
  <a href={`mailto:${site.email}`}>Start a sprint</a>
</section>

<style>
  .archive-notice {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 16px clamp(18px, 5vw, 64px);
    border-bottom: 1px solid rgba(6, 182, 212, 0.2);
    background: rgba(10, 10, 30, 0.9);
  }

  strong {
    display: block;
    margin-bottom: 2px;
    color: #06b6d4;
  }

  p {
    max-width: 860px;
    font-size: 14px;
    color: #a5f3fc;
  }

  a {
    flex: 0 0 auto;
    color: #06b6d4;
    font-weight: 800;
  }

  a:hover {
    text-shadow: 0 0 8px rgba(6, 182, 212, 0.5);
  }

  @media (max-width: 700px) {
    .archive-notice {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
