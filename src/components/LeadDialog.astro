---
const email = "hello@starkmeta.net";
---
<dialog id="lead-dialog"><form class="lead-form" data-lead-form action={`https://formsubmit.co/ajax/${email}`} method="POST"><button class="close" type="button" data-close aria-label="Close">×</button><p class="eyebrow">Start a conversation</p><h2>Tell us what you are building.</h2><label>Name<input name="name" required autocomplete="name" /></label><label>Email<input name="email" type="email" required autocomplete="email" /></label><label>Project<textarea name="message" rows="4" placeholder="A few useful details"></textarea></label><input type="hidden" name="_subject" value="New website enquiry" /><button class="button" type="submit">Send request</button><p class="form-status" aria-live="polite"></p></form></dialog>
<script>
const dialog=document.querySelector('#lead-dialog');document.querySelectorAll('[data-lead]').forEach((button)=>button.addEventListener('click',(event)=>{event.preventDefault();dialog?.showModal();}));dialog?.querySelector('[data-close]')?.addEventListener('click',()=>dialog.close());dialog?.addEventListener('click',(event)=>{if(event.target===dialog)dialog.close();});document.querySelector('[data-lead-form]')?.addEventListener('submit',async(event)=>{event.preventDefault();const form=event.currentTarget;const status=form.querySelector('.form-status');status.textContent='Sending…';try{const response=await fetch(form.action,{method:'POST',body:new FormData(form),headers:{Accept:'application/json'}});if(!response.ok)throw new Error();form.reset();status.textContent='Thank you! We have received your request and will contact you soon.';}catch{status.textContent='Please try again or email us directly.';}});
</script>
<style>dialog{width:min(560px,calc(100% - 28px));border:0;border-radius:24px;padding:0;background:#fff;color:#111;box-shadow:0 30px 100px #0008}dialog::backdrop{background:#07111dcc;backdrop-filter:blur(8px)}.lead-form{display:grid;gap:16px;padding:clamp(24px,5vw,44px);position:relative}.lead-form h2{margin:0}.lead-form label{display:grid;gap:7px;font-weight:700;font-size:14px}.lead-form input,.lead-form textarea{width:100%;border:1px solid #ccd2db;border-radius:10px;padding:12px;font:inherit}.close{position:absolute;right:18px;top:14px;border:0!important;background:transparent!important;color:#111!important;box-shadow:none!important;font-size:30px;cursor:pointer}.form-status{font-weight:700;margin:0}</style>
