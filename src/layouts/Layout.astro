---
import { navItems, site } from "@/config/site";

type Props = {
  title?: string;
  description?: string;
};

const title = Astro.props.title ? `${Astro.props.title} | ${site.name}` : site.name;
const description = Astro.props.description || site.description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${site.name} home`}>
        <img src="/assets/logo.png" alt="" class="brand-mark" />
        <span>{site.name}</span>
      </a>
      <button class="menu-button" type="button" aria-label="Open navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="site-nav" aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a class="brand footer-brand" href="/" aria-label={`${site.name} home`}>
        <img src="/assets/logo.png" alt="" class="brand-mark" />
        <span>{site.name}</span>
      </a>
          <p>{site.description}</p>
        </div>
        <div class="footer-columns">
          <div class="footer-column">
            <h3>Company</h3>
            <ul>
              <li><a href="/">Home</a></li>
              <li><a href="/blog/">Blog</a></li>
              <li><a href="/contact/">Contact</a></li>
              <li><a href="/privacy/">Privacy</a></li>
              <li><a href="/terms/">Terms</a></li>
            </ul>
          </div>
          <div class="footer-column">
            <h3>Resources</h3>
            <ul>
              <li><a href="/docs/">Docs</a></li>
              <li><a href="/faq/">FAQ</a></li>
              <li><a href="/blog/">Articles</a></li>
            </ul>
          </div>
          <div class="footer-column">
            <h3>Support</h3>
            <ul>
              <li><a href="/contact/">Help Center</a></li>
              <li><a href="mailto:support@starkmeta.net">support@starkmeta.net</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</p>
      </div>
    </footer>
    <script>
      const button = document.querySelector(".menu-button");
      const nav = document.querySelector(".site-nav");
      button?.addEventListener("click", () => {
        const isOpen = nav?.classList.toggle("is-open") || false;
        button.setAttribute("aria-expanded", String(isOpen));
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --ink: #ecfeff;
    --muted: #67e8f9;
    --line: rgba(6, 182, 212, 0.2);
    --panel: rgba(10, 10, 30, 0.8);
    --soft: #050510;
    --accent: #06b6d4;
    --accent-strong: #3b82f6;
    --gold: #f97316;
    --blue: #3b82f6;
    --shadow: 0 18px 50px rgba(6, 182, 212, 0.15);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--soft);
    color: var(--ink);
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  svg {
    max-width: 100%;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px clamp(18px, 5vw, 64px);
    border-bottom: 1px solid rgba(6, 182, 212, 0.2);
    background: rgba(5, 5, 16, 0.92);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    letter-spacing: 0;
    white-space: nowrap;
  }

  .brand-mark {
    display: block;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    object-fit: cover;
    background: transparent;
  }

  .brand-mark-OLD {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border-radius: 8px;
    background: linear-gradient(135deg, #06b6d4, #3b82f6);
    color: #fff;
    font-size: 17px;
    box-shadow: 0 0 12px rgba(6, 182, 212, 0.4);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: clamp(14px, 2vw, 26px);
    color: var(--muted);
    font-size: 15px;
    font-weight: 650;
  }

  .site-nav a:hover {
    color: var(--accent);
    text-shadow: 0 0 8px rgba(6, 182, 212, 0.5);
  }

  .menu-button {
    display: none;
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(10, 10, 30, 0.8);
  }

  .menu-button span {
    display: block;
    width: 18px;
    height: 2px;
    margin: 3px auto;
    background: var(--accent);
  }

  .section {
    padding: clamp(58px, 8vw, 104px) clamp(18px, 5vw, 64px);
  }

  .section-inner {
    width: min(1120px, 100%);
    margin: 0 auto;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--accent);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 900px;
    margin: 0;
    font-size: clamp(42px, 8vw, 88px);
    line-height: 0.96;
    letter-spacing: 0;
  }

  h2 {
    max-width: 780px;
    margin: 0 0 18px;
    font-size: clamp(30px, 4vw, 52px);
    line-height: 1.05;
    letter-spacing: 0;
  }

  h3 {
    margin: 0 0 10px;
    font-size: 21px;
    line-height: 1.2;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  .lead {
    max-width: 720px;
    margin-top: 24px;
    color: #a5f3fc;
    font-size: clamp(18px, 2vw, 22px);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .button {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    padding: 12px 18px;
    border: 1px solid var(--accent);
    background: linear-gradient(135deg, #06b6d4, #3b82f6);
    color: #fff;
    font-weight: 760;
    box-shadow: 0 0 16px rgba(6, 182, 212, 0.3);
    transition: box-shadow 0.2s ease;
  }

  .button:hover {
    box-shadow: 0 0 24px rgba(6, 182, 212, 0.5);
  }

  .button.secondary {
    border-color: rgba(6, 182, 212, 0.35);
    background: transparent;
    color: var(--ink);
    box-shadow: none;
  }

  .button.secondary:hover {
    box-shadow: 0 0 16px rgba(6, 182, 212, 0.2);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .card {
    border: 1px solid rgba(6, 182, 212, 0.2);
    border-radius: 8px;
    background: rgba(10, 10, 30, 0.8);
    padding: 24px;
    box-shadow: 0 1px 0 rgba(6, 182, 212, 0.05);
  }

  .band {
    background: rgba(10, 10, 30, 0.5);
    border-top: 1px solid rgba(6, 182, 212, 0.1);
    border-bottom: 1px solid rgba(6, 182, 212, 0.1);
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
    padding: 44px clamp(18px, 5vw, 64px);
    border-top: 1px solid var(--line);
    background: #050510;
  }

  .site-footer p {
    max-width: 520px;
    margin-top: 12px;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    gap: 16px;
    color: var(--muted);
    font-weight: 650;
  }

  .footer-links a:hover {
    color: var(--accent);
    text-shadow: 0 0 8px rgba(6, 182, 212, 0.5);
  }

  .article-body {
    max-width: 760px;
  }

  .article-body p,
  .article-body li {
    color: #a5f3fc;
    font-size: 18px;
  }

  .article-body p + p,
  .article-body ul + p {
    margin-top: 20px;
  }

  .article-body code,
  pre {
    white-space: pre-wrap;
    word-break: break-word;
  }

  @media (max-width: 780px) {
    .site-header {
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .menu-button {
      display: grid;
    }

    .site-nav {
      display: none;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding-top: 8px;
    }

    .site-nav.is-open {
      display: flex;
    }

    .site-nav a {
      border-top: 1px solid var(--line);
      padding: 12px 0;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .site-footer {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 24px;
    }

    .footer-links {
      justify-content: center;
    }
  }

  /* === Design/layout improvements === */

  /* Link contrast */
  .article-body a,
  .article-body a:link,
  .article-layout a,
  main a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    font-weight: 600;
  }

  .article-body a:hover,
  .article-body a:focus,
  .article-layout a:hover,
  main a:hover {
    color: var(--gold, var(--accent-strong));
  }

  .article-body a:visited {
    color: var(--accent-strong);
  }

  /* Typography for article headings */
  .article-body h1 {
    margin: 0 0 1.25rem;
    font-size: clamp(2.2rem, 5vw, 3rem);
    line-height: 1.15;
    color: var(--ink);
  }

  .article-body h2 {
    margin: 2.25rem 0 1rem;
    font-size: clamp(1.6rem, 3.5vw, 2.1rem);
    line-height: 1.25;
    color: var(--ink);
  }

  .article-body h3 {
    margin: 1.75rem 0 0.75rem;
    font-size: clamp(1.35rem, 2.8vw, 1.7rem);
    line-height: 1.3;
    color: var(--ink);
  }

  .article-body h4 {
    margin: 1.5rem 0 0.6rem;
    font-size: 1.15rem;
    color: var(--ink);
  }

  .article-body h5 {
    margin: 1.25rem 0 0.5rem;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink);
  }

  .article-body h6 {
    margin: 1rem 0 0.5rem;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  .article-body p {
    margin: 0 0 1.25rem;
    line-height: 1.75;
    color: var(--muted);
  }

  .article-body ul,
  .article-body ol {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .article-body li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
  }

  .article-body th,
  .article-body td {
    border: 1px solid var(--line);
    padding: 0.6rem 0.8rem;
    text-align: left;
  }

  .article-body th {
    background: rgba(255, 255, 255, 0.05);
    color: var(--ink);
  }

  /* Breadcrumbs */
  .breadcrumbs {
    max-width: 1120px;
    margin: 0 auto;
    padding: 1rem clamp(18px, 5vw, 64px);
    font-size: 0.875rem;
    color: var(--muted);
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .breadcrumbs li:not(:last-child)::after {
    content: "/";
    margin-left: 0.5rem;
    color: var(--muted);
  }

  .breadcrumbs a {
    color: var(--accent);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  .breadcrumbs [aria-current="page"] {
    display: inline-block;
    max-width: min(420px, 60vw);
    font-weight: 600;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    vertical-align: bottom;
  }

  /* Richer footer */
  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 2fr;
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-brand p {
    max-width: 320px;
    margin-top: 1rem;
    line-height: 1.7;
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .footer-column h3 {
    margin: 0 0 1rem;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink);
  }

  .footer-column ul {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-column a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-column a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 2.5rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    text-align: center;
    font-size: 0.875rem;
    color: var(--muted);
  }

  @media (max-width: 780px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .footer-columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 480px) {
    .footer-columns {
      grid-template-columns: 1fr;
    }
  }

</style>