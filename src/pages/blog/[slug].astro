---
import Layout from "@/layouts/Layout.astro";
import { getBlogPosts } from "@/lib/squidex";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
---

<Layout title={post.title} description={post.description}>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li><a href="/blog/">Blog</a></li>
      <li><span aria-current="page">{post.title}</span></li>
    </ol>
  </nav>
  <article>
    <section class="section band">
      <div class="section-inner article-layout">
        <div>
          <div class="article-body" set:html={post.articleText} />
          {post.inlineImages.length > 0 && (
            <div class="inline-images" aria-label="Article visuals">
              {post.inlineImages.map((image) => <img src={image} alt="" loading="lazy" />)}
            </div>
          )}
        </div>
        <aside class="card">
          <h2>Article details</h2>
          <p><strong>Author</strong><br />{post.author}</p>
          <p><strong>Published</strong><br />{new Date(post.pubDate).toLocaleDateString("ru-RU")}</p>
          <p><strong>Tags</strong><br />{post.tags.join(", ")}</p>
          {post.referenceUrl && <p><strong>Reference</strong><br /><a href={post.referenceUrl} target="_blank" rel="noreferrer">Open source</a></p>}
        </aside>
      </div>
    </section>
  </article>
</Layout>

<style>
  .article-cover {
    width: 100%;
    max-height: 420px;
    margin-top: 34px;
    border: 1px solid rgba(17, 24, 39, 0.14);
    border-radius: 8px;
    object-fit: cover;
    box-shadow: var(--shadow);
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 310px;
    gap: 42px;
    align-items: start;
  }

  aside h2 {
    font-size: 22px;
  }

  aside p + p {
    margin-top: 18px;
  }

  .inline-images {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin-top: 30px;
  }

  .inline-images img {
    width: 100%;
    border: 1px solid rgba(17, 24, 39, 0.12);
    border-radius: 8px;
    background: #fff;
  }

  a {
    color: var(--accent);
    font-weight: 700;
    text-decoration: underline;
  }
  a:hover {
    color: var(--gold, var(--accent-strong));
  }

  @media (max-width: 860px) {
    .article-layout {
      grid-template-columns: 1fr;
    }

    .inline-images {
      grid-template-columns: 1fr;
    }
  }
</style>
