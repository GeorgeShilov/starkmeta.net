---
import Layout from "@/layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<"blog"> };
const { post } = Astro.props as Props;
const { Content } = await post.render();
const { data } = post;
const inlineImages = data.inlineImages ?? [];
const referenceUrl = data.referenceUrl?.trim() || "";
const pubDate = data.pubDate;
---

<Layout title={data.title} description={data.description}>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li><a href="/blog/">Blog</a></li>
      <li><span aria-current="page">{data.title}</span></li>
    </ol>
  </nav>
  <article>
    <section class="section band">
      <div class="section-inner article-layout">
        <div>
          <div class="article-body">
            <Content />
          </div>
          {
            inlineImages.length > 0 && (
              <div class="inline-images" aria-label="Article visuals">
                {inlineImages.map((image) => (
                  <img src={image} alt="" loading="lazy" />
                ))}
              </div>
            )
          }
        </div>
        <aside class="card">
          <h2>Article details</h2>
          <p><strong>Author</strong><br />{data.author}</p>
          <p><strong>Published</strong><br />{pubDate.toLocaleDateString("ru-RU")}</p>
          <p><strong>Tags</strong><br />{data.tags.length ? data.tags.join(", ") : "—"}</p>
          {
            referenceUrl && (
              <p>
                <strong>Reference</strong>
                <br />
                <a href={referenceUrl} target="_blank" rel="noreferrer">Open source</a>
              </p>
            )
          }
        </aside>
      </div>
    </section>
  </article>
</Layout>

<style>
  .article-cover {
    width: 100%;
    max-height: 420px;
    margin-top: 34px;
    border: 1px solid rgba(17, 24, 39, 0.14);
    border-radius: 8px;
    object-fit: cover;
    box-shadow: var(--shadow);
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 310px;
    gap: 42px;
    align-items: start;
  }

  aside h2 {
    font-size: 22px;
  }

  aside p + p {
    margin-top: 18px;
  }

  .inline-images {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin-top: 30px;
  }

  .inline-images img {
    display: block; height: auto; max-width: 100%; width: 100%;
    border: 1px solid rgba(17, 24, 39, 0.12);
    border-radius: 8px;
    background: #fff;
  }

  a {
    color: var(--accent);
    font-weight: 700;
    text-decoration: underline;
  }
  a:hover {
    color: var(--gold, var(--accent-strong));
  }

  @media (max-width: 860px) {
    .article-layout {
      grid-template-columns: 1fr;
    }

    .inline-images {
      grid-template-columns: 1fr;
    }
  }
  .article-body :global(img) { max-width: 100%; height: auto; display: block; margin: 1.5rem 0; }

  /* Mobile overflow containment */
  .content,
  .article-body,
  .prose {
    max-width: 100%;
    overflow-wrap: anywhere;
    word-break: break-word;
    min-width: 0;
  }

  .content :global(table),
  .article-body :global(table),
  :global(.prose table) {
    display: block;
    overflow-x: auto;
    max-width: 100%;
  }

  .content :global(pre),
  .article-body :global(pre),
  :global(.prose pre) {
    overflow-x: auto;
    white-space: pre;
    word-break: normal;
    max-width: 100%;
  }

  .content :global(a),
  .article-body :global(a),
  :global(.prose a) {
    overflow-wrap: anywhere;
  }

  @media (max-width: 600px) {
    .blog-post,
    .post {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>
