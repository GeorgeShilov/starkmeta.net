---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Docs">
  <section class="section">
    <div class="section-inner docs">
      <p class="eyebrow">Docs</p>
      <h1>Studio documentation</h1>
      <p class="lead">A concise reference for metaverse world building, NFT integration, and Unreal Engine deployment.</p>
      <article class="card">
        <h2>Required assets</h2>
        <ul>
          <li>Generate no more than 2-3 logo variants before choosing a primary StarkMeta mark.</li>
          <li>Create one hero background for the homepage and a reusable Open Graph visual.</li>
          <li>Create at least three images per blog post: one cover and two inline images.</li>
          <li>Store prompt metadata next to generated assets so the visual system is reproducible.</li>
        </ul>
      </article>
      <article class="card">
        <h2>Suggested environment variables</h2>
        <pre><code>SITE_URL=https://starkmeta.net
UE_PROJECT=StarkMeta
NFT_CONTRACT=...
MARKETPLACE_OPENSEA=...</code></pre>
      </article>
    </div>
  </section>
</Layout>

<style>
  .docs {
    display: grid;
    gap: 24px;
  }

  ul {
    margin: 0;
    padding-left: 22px;
    color: #354052;
  }

  pre {
    overflow: auto;
    margin: 0;
    border-radius: 8px;
    background: #111827;
    color: #fff;
    padding: 18px;
  }
</style>
