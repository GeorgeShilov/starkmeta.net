---
import Layout from "@/layouts/Layout.astro";

const faqs = [
  ["What is StarkMeta building?", "Unreal Engine-based metaverse worlds with P2E NFT games, dynamic cities, racing arenas, and collectible digital assets."],
  ["How do NFTs work in StarkMeta games?", "In-game items are minted as NFTs with embedded rarity. Players can trade them on OpenSea or through in-game marketplaces."],
  ["What platforms will StarkMeta support?", "PC first, with Web3 wallet integration for asset ownership and marketplace trading across StarkNet and Ethereum."],
  ["How can I partner with StarkMeta?", "Reach out via the Contact page for publishing, IP licensing, blockchain integration, and co-development opportunities."]
];
---

<Layout title="FAQ">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">FAQ</p>
      <h1>Clear answers before entering the world.</h1>
      <div class="faq-list">
        {faqs.map(([question, answer]) => (
          <details class="card">
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .faq-list {
    display: grid;
    gap: 14px;
    margin-top: 40px;
  }

  summary {
    cursor: pointer;
    font-weight: 800;
    font-size: 20px;
  }

  details p {
    margin-top: 14px;
  }
</style>
