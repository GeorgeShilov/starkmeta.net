---
import Layout from "@/layouts/Layout.astro";

const faqs = [
  ["What does Codex Workplace launch first?", "A polished SaaS website with homepage, pricing, docs, FAQ, contact, blog, SEO metadata, generated visuals, and deployment-ready assets."],
  ["How many logo options are generated?", "Only 2-3 variants. The goal is fast direction, not endless brand exploration."],
  ["How many blog images are required?", "Every blog post gets at least three images: one cover image and two inline visuals for the article body."],
  ["Where do Cloudflare and Railway fit?", "Cloudflare handles domain, DNS, SSL, CDN, and static frontend hosting. Railway handles backend services, APIs, and databases when the SaaS needs them."]
];
---

<Layout title="FAQ">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">FAQ</p>
      <h1>Clear answers before the first work sprint.</h1>
      <div class="faq-list">
        {faqs.map(([question, answer]) => (
          <details class="card">
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .faq-list {
    display: grid;
    gap: 14px;
    margin-top: 40px;
  }

  summary {
    cursor: pointer;
    font-weight: 800;
    font-size: 20px;
  }

  details p {
    margin-top: 14px;
  }
</style>
