---
import ArchiveNotice from "@/components/ArchiveNotice.astro";
import PostCard from "@/components/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/config/site";
import { getBlogPosts } from "@/lib/squidex";

const posts = await getBlogPosts();
const featured = posts.find((post) => post.featured) || posts[0];
---

<Layout title="StarkMeta / Metaverse infrastructure" description={site.description}>
  <ArchiveNotice />
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">StarkMeta / Metaverse infrastructure</p>
      <h1>Build worlds. Own realms. Scale on StarkNet.</h1>
      <p class="lead">
        StarkMeta provides the infrastructure layer for persistent metaverse worlds, on-chain digital
        identity, and scalable blockchain economies powered by StarkNet.
      </p>
      <div class="button-row">
        <a class="button" href="/gateway/">Explore command OS</a>
        <a class="button secondary" href="/blog/">Read field notes</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="StarkMeta signal summary">
      <div>
        <span>Core view</span>
        <strong>Metaverse &amp; blockchain control</strong>
      </div>
      <div>
        <span>Signals</span>
        <strong>Worlds, identity, on-chain economy</strong>
      </div>
      <div>
        <span>Chain layer</span>
        <strong>StarkNet validity rollup</strong>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="section-inner split">
      <div>
        <p class="eyebrow">Why it exists</p>
        <h2>The metaverse needs infrastructure before it needs hype.</h2>
      </div>
      <div class="history-list">
        {site.launchContext.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Command architecture</p>
      <h2>One protocol layer for the open metaverse.</h2>
      <div class="grid">
        <article class="card">
          <h3>Realm engine</h3>
          <p>Deploy persistent worlds with on-chain land, ownership, and provable state.</p>
        </article>
        <article class="card">
          <h3>Identity layer</h3>
          <p>Portable avatars and verifiable reputation across every connected world.</p>
        </article>
        <article class="card">
          <h3>Economy protocol</h3>
          <p>Cairo smart contracts for creator royalties, marketplaces, and cross-realm assets.</p>
        </article>
      </div>
    </div>
  </section>

  {featured && (
    <section class="section band">
      <div class="section-inner">
        <p class="eyebrow">Featured note</p>
        <h2>Start with realm command.</h2>
        <PostCard post={featured} />
      </div>
    </section>
  )}
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(28px, 5vw, 72px);
    min-height: calc(100vh - 68px);
    align-items: center;
    padding: clamp(58px, 8vw, 110px) clamp(18px, 5vw, 64px) clamp(42px, 6vw, 80px);
    background:
      radial-gradient(ellipse at 20% 20%, rgba(88, 28, 135, 0.35) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 80%, rgba(30, 58, 138, 0.35) 0%, transparent 60%),
      linear-gradient(135deg, #0b0f19 0%, #0f172a 40%, #1e1b4b 70%, #0f172a 100%);
    color: #fff;
  }

  .hero-copy {
    max-width: 860px;
  }

  .hero .lead {
    color: rgba(255, 255, 255, 0.78);
  }

  .hero-panel {
    display: grid;
    gap: 12px;
    padding: 18px;
    border: 1px solid rgba(17, 24, 39, 0.14);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: var(--shadow);
  }

  .hero-panel div {
    border-bottom: 1px solid #d9dee8;
    padding: 14px;
  }

  .hero-panel div:last-child {
    border-bottom: 0;
  }

  .hero-panel span {
    display: block;
    color: #5c6676;
    font-size: 13px;
    font-weight: 800;
  }

  .hero-panel strong {
    display: block;
    margin-top: 5px;
    color: #101828;
    font-size: 20px;
    line-height: 1.2;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 36px;
  }

  .history-list {
    display: grid;
    gap: 16px;
  }

  .history-list p {
    border-left: 4px solid #06b6d4;
    padding-left: 16px;
  }

  @media (max-width: 860px) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      background-size: 720px;
      background-position: center bottom;
      padding-bottom: 300px;
    }
  }
</style>
