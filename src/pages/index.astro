---
import ArchiveNotice from "@/components/ArchiveNotice.astro";
import PostCard from "@/components/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { site } from "@/config/site";
import { getBlogPosts } from "@/lib/squidex";

const posts = await getBlogPosts();
const sorted = [...posts].sort(
  (a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
);
const latest3 = sorted.slice(0, 3);
---

<Layout title="StarkMeta / Unreal Engine Metaverse" description={site.description}>
  <ArchiveNotice />
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">StarkMeta / Unreal Engine Metaverse</p>
      <h1>Metaverse P2E games based on Unreal Engine.</h1>
      <p class="lead">
        StarkMeta is a metaverse studio building immersive play-to-earn NFT games, dynamic digital
        worlds, and collectible NFT experiences powered by Unreal Engine.
      </p>
      <div class="button-row">
        <a class="button" href="/games/">Explore games</a>
        <a class="button secondary" href="/blog/">Read updates</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="StarkMeta signal summary">
      <div>
        <span>Core focus</span>
        <strong>Unreal Engine metaverse &amp; P2E games</strong>
      </div>
      <div>
        <span>Features</span>
        <strong>NFT collecting, racing, open worlds</strong>
      </div>
      <div>
        <span>Economy</span>
        <strong>SMETA rewards &amp; OpenSea trading</strong>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="section-inner split">
      <div>
        <p class="eyebrow">Why it exists</p>
        <h2>The metaverse needs games before it needs hype.</h2>
      </div>
      <div class="history-list">
        {site.launchContext.map((item) => <p>{item}</p>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Game architecture</p>
      <h2>One studio. Multiple worlds. True ownership.</h2>
      <div class="grid">
        <article class="card">
          <h3>Unreal worlds</h3>
          <p>Dynamic cities, open worlds, and racing arenas built with Unreal Engine graphics.</p>
        </article>
        <article class="card">
          <h3>NFT collecting</h3>
          <p>In-game NFTs scattered through play, tradable on OpenSea with embedded rarity.</p>
        </article>
        <article class="card">
          <h3>P2E economy</h3>
          <p>SMETA rewards, creator royalties, and marketplace contracts for cross-game assets.</p>
        </article>
      </div>
    </div>
  </section>

  {latest3.length > 0 && (
    <section class="section band">
      <div class="section-inner">
        <p class="eyebrow">Latest updates</p>
        <h2>Fresh news from the StarkMeta studio.</h2>
        <div class="latest-row">
          {latest3.map((post) => <PostCard post={post} />)}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(28px, 5vw, 72px);
    min-height: calc(100vh - 68px);
    align-items: center;
    padding: clamp(58px, 8vw, 110px) clamp(18px, 5vw, 64px) clamp(42px, 6vw, 80px);
    background:
      radial-gradient(ellipse at 20% 20%, rgba(6, 182, 212, 0.25) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 80%, rgba(59, 130, 246, 0.25) 0%, transparent 60%),
      linear-gradient(135deg, #050510 0%, #0a0a1e 40%, #050510 70%, #0a0a1e 100%);
    color: #ecfeff;
  }

  .hero-copy {
    max-width: 860px;
  }

  .hero .lead {
    color: rgba(103, 232, 249, 0.85);
  }

  .hero .button {
    background: linear-gradient(135deg, #06b6d4, #3b82f6);
    border-color: transparent;
    color: #fff;
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.35);
  }

  .hero .button:hover {
    box-shadow: 0 0 28px rgba(6, 182, 212, 0.55);
  }

  .hero .button.secondary {
    background: transparent;
    border-color: rgba(6, 182, 212, 0.35);
    color: #ecfeff;
    box-shadow: none;
  }

  .hero .button.secondary:hover {
    box-shadow: 0 0 16px rgba(6, 182, 212, 0.2);
  }

  .hero-panel {
    display: grid;
    gap: 12px;
    padding: 18px;
    border: 1px solid rgba(6, 182, 212, 0.2);
    border-radius: 8px;
    background: rgba(10, 10, 30, 0.8);
    box-shadow: 0 0 30px rgba(6, 182, 212, 0.1);
  }

  .hero-panel div {
    border-bottom: 1px solid rgba(6, 182, 212, 0.15);
    padding: 14px;
  }

  .hero-panel div:last-child {
    border-bottom: 0;
  }

  .hero-panel span {
    display: block;
    color: #67e8f9;
    font-size: 13px;
    font-weight: 800;
  }

  .hero-panel strong {
    display: block;
    margin-top: 5px;
    color: #ecfeff;
    font-size: 20px;
    line-height: 1.2;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 36px;
  }

  .history-list {
    display: grid;
    gap: 16px;
  }

  .history-list p {
    border-left: 4px solid #06b6d4;
    padding-left: 16px;
    color: #a5f3fc;
  }

  .latest-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    margin-top: 36px;
  }

  @media (max-width: 860px) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      background-size: 720px;
      background-position: center bottom;
      padding-bottom: 300px;
    }

    .latest-row {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>
