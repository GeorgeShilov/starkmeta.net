---
import Layout from '@/layouts/Layout.astro'; import LeadDialog from '@/components/LeadDialog.astro';
---
<Layout title="Worldbuilding studio"><div class="world"><section class="chapter hero"><nav><b>STARKMETA</b><span>REALTIME WORLDS / UNREAL EXPERIENCES</span><button data-lead>Start a world</button></nav><img src="/assets/generated/hero-world.jpg" alt="Cinematic realtime fantasy world"/><div><p>CHAPTER I / THE THRESHOLD</p><h1>Enter the<br/><i>impossible.</i></h1></div><span class="scroll">SCROLL TO DESCEND ↓</span></section><section class="chapter idea"><small>CHAPTER II / WORLD SYSTEMS</small><h2>We build places that remember you.</h2><div class="triptych"><article><b>Living environments</b><p>Weather, light and story moving together.</p></article><article><b>Playable identity</b><p>Characters and objects with a distinct visual language.</p></article><article><b>Realtime wonder</b><p>Unreal Engine scenes tuned for spectacle and speed.</p></article></div></section><section class="chapter crew"><img src="/assets/generated/worldbuilders.jpg" alt="Realtime worldbuilding artists"/><div><small>CHAPTER III / THE MAKERS</small><h2>Artists, technologists, myth-makers.</h2><p>One integrated studio from first sketch to playable world.</p><button data-lead>Cross the threshold</button></div></section><LeadDialog /></div></Layout>
<style>:global(.site-header),:global(.site-footer){display:none}.world{background:#09090b;color:white;font-family:Arial,sans-serif}.chapter{min-height:100vh;position:relative}.hero>img{position:absolute;width:100%;height:100%;object-fit:cover;filter:brightness(.65)}.hero nav{position:absolute;z-index:2;left:0;right:0;display:flex;justify-content:space-between;padding:25px 4vw;border-bottom:1px solid #fff4}.hero nav button,.crew button{border:1px solid white;color:white;background:transparent;border-radius:100px;padding:11px 18px}.hero>div{position:absolute;z-index:1;left:5vw;bottom:12vh}.hero h1{font-size:clamp(5rem,13vw,13rem);line-height:.72;letter-spacing:-.07em;margin:.15em 0}.hero h1 i{font-family:Georgia,serif;font-weight:400;color:#b0ff6d}.scroll{position:absolute;right:4vw;bottom:4vw;font-size:.7rem;letter-spacing:.2em}.idea{padding:10vw 5vw;background:radial-gradient(circle at 80% 20%,#402653,#09090b 45%)}.idea h2{font:clamp(4rem,9vw,9rem)/.92 Georgia,serif;max-width:1100px}.triptych{display:grid;grid-template-columns:repeat(3,1fr);margin-top:10vw}.triptych article{padding:30px;border-top:1px solid #fff6}.triptych b{font-size:1.4rem}.triptych p{color:#aaa}.crew{display:grid;grid-template-columns:1.25fr 1fr;align-items:center}.crew img{width:100%;height:100vh;object-fit:cover}.crew div{padding:6vw}.crew h2{font:clamp(3.5rem,6vw,6rem)/.95 Georgia,serif}@media(max-width:760px){.hero nav span{display:none}.triptych,.crew{grid-template-columns:1fr}.crew img{height:55vh}.idea h2{font-size:4rem}}</style>
