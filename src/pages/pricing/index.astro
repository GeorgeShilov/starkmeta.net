---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Pricing">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Pricing</p>
      <h1>Pick the command layer.</h1>
      <p class="lead">
        Start with a focused work view, then add content workflows, backend integrations, and
        deeper funnel reporting as traction becomes clear.
      </p>
      <div class="grid pricing">
        <article class="card"><h3>Signal</h3><p>Work brief, launch page, generated visuals, and lightweight funnel review.</p><strong>$490</strong></article>
        <article class="card"><h3>Command</h3><p>Full SaaS site, blog starter pack, campaign map, and Cloudflare deployment.</p><strong>$1,400</strong></article>
        <article class="card"><h3>Scale</h3><p>Railway backend, data integrations, content workflow, analytics, and iteration support.</p><strong>Custom</strong></article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .pricing {
    margin-top: 42px;
  }

  strong {
    display: block;
    margin-top: 28px;
    font-size: 30px;
  }
</style>
