---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Pricing">
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Pricing</p>
      <h1>Choose your entry point.</h1>
      <p class="lead">
        Start with NFT collectibles, then expand into full worlds, P2E economies, and custom
        Unreal Engine development.
      </p>
      <div class="grid pricing">
        <article class="card"><h3>Starter</h3><p>Character or item NFT collection design, metadata, and OpenSea listing setup.</p><strong>$490</strong></article>
        <article class="card"><h3>World</h3><p>Unreal Engine level, playable prototype, NFT integration, and marketplace contracts.</p><strong>$1,400</strong></article>
        <article class="card"><h3>Studio</h3><p>Full P2E game, custom metaverse world, ongoing live ops, and cross-game assets.</p><strong>Custom</strong></article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .pricing {
    margin-top: 42px;
  }

  strong {
    display: block;
    margin-top: 28px;
    font-size: 30px;
  }
</style>
