---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Privacy">
  <section class="section">
    <div class="section-inner article-body">
      <p class="eyebrow">Privacy</p>
      <h1>Privacy policy</h1>
      <p>
        This launch does not include user accounts, payment forms, or customer dashboards. If you
        email the Codex Workplace contact address, your message and address are used only to respond.
      </p>
      <p>
        Hosting providers may collect standard server logs such as IP address, user agent, request
        path, and timestamp for security and operations. Future content workflows may use a CMS or
        image generation API when credentials are configured.
      </p>
    </div>
  </section>
</Layout>
